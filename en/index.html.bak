    <!-- Hero -->
    <section class="pt-16 pb-6">
      <div class="w-full px-6">
        <div id="hero-layout" style="padding-top:100px;padding-bottom:40px;position:relative;">
          <div class="hero-top">
            <div class="hero-logo-wrap">
              <svg id="Layer_1" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 1458.99 347.83" preserveAspectRatio="xMidYMid meet" class="w-full h-auto mx-auto overflow-visible">
                <defs><style>
                  .logo-path { fill:rgba(255,255,255,0.32); stroke:rgba(255,255,255,0.68); stroke-width:0.8; stroke-linecap:round; stroke-linejoin:round; stroke-dasharray:2000; stroke-dashoffset:2000; fill-opacity:0; }
                  .letter-i  { animation:drawLine 0.8s ease-in-out forwards,       revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-n1 { animation:drawLine 0.8s ease-in-out 0.15s forwards, revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-f  { animation:drawLine 0.8s ease-in-out 0.3s forwards,  revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-i2 { animation:drawLine 0.8s ease-in-out 0.45s forwards, revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-n2 { animation:drawLine 0.8s ease-in-out 0.6s forwards,  revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-i3 { animation:drawLine 0.8s ease-in-out 0.75s forwards, revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-q  { animation:drawLine 0.8s ease-in-out 0.9s forwards,  revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-u  { animation:drawLine 0.8s ease-in-out 1.05s forwards, revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-e  { animation:drawLine 0.8s ease-in-out 1.2s forwards,  revealFill 0.8s ease-out 2.15s forwards; }
                  .letter-star { animation:drawLine 0.8s ease-in-out 1.35s forwards, revealFill 0.8s ease-out 2.15s forwards; }
                  @keyframes drawLine   { 0%{stroke-dashoffset:2000} 100%{stroke-dashoffset:0} }
                  @keyframes revealFill { 0%{fill-opacity:0} 100%{fill-opacity:1} }
                
    /* Footer responsive */
    @media (max-width: 768px) {
      .footer-main-row {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 32px !important;
      }
      .footer-main-row > div:last-child {
        align-items: flex-start !important;
      }
      .footer-addr {
        flex-wrap: wrap !important;
        white-space: normal !important;
      }
    }

/* Responsive <br> utilities */
.br-sm, .br-md, .br-lg { display: none; }
@media (max-width: 767px) { .br-sm { display: inline; } }
@media (min-width: 768px) and (max-width: 1023px) { .br-md { display: inline; } }
@media (min-width: 1024px) { .br-lg { display: inline; } }
@media (max-width: 767px) { .br-hide-sm { display: none !important; } }
@media (min-width: 768px) and (max-width: 1023px) { .br-hide-md { display: none !important; } }
@media (min-width: 1024px) { .br-hide-lg { display: none !important; } }
/* Convenience combos */
@media (max-width: 1023px) { .br-lg-only { display: none !important; } }
@media (min-width: 768px) { .br-sm-only { display: none !important; } }

@media (max-width: 767px) {
  .card-overlay { background: rgba(0,0,0,0.25) !important; }
}

@media (max-width: 768px) {
  .footer-main-row img[alt="Infinique"],
  .footer-main-row img[alt="Dev logo"] { width: 120px !important; }
}

@media (max-width: 768px) {
  footer .text-lg { font-size: 12px !important; }
  footer .footer-copy p, footer .footer-copy { font-size: 11px !important; }
  footer p { font-size: 11px !important; }
  footer .footer-addr,
  footer .footer-addr a,
  footer .footer-addr span { font-size: 12px !important; }
  footer .footer-addr a svg { width: 14px !important; height: 14px !important; }
  footer .footer-addr > .text-lg,
  footer .footer-addr > a,
  footer .footer-addr > a span { white-space: nowrap !important; }
}
@media (max-width: 360px) {
  footer .text-lg { font-size: 11px !important; }
  footer p { font-size: 10px !important; }
  footer .footer-addr,
  footer .footer-addr a,
  footer .footer-addr span { font-size: 11px !important; }
  footer .footer-addr a svg { width: 12px !important; height: 12px !important; }
  .footer-main-row img[alt="Infinique"],
  .footer-main-row img[alt="Dev logo"] { width: 100px !important; }
}
</style></defs>
