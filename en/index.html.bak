  <meta property="og:image:width" content="1120">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Infinique — Presentation Design Studio">
  <meta name="twitter:description" content="Strategy, structure, and design — one seamless flow for every presentation.">
  <meta name="twitter:image" content="https://infinique.kr/assets/og.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://umzfjxrrotvwcmurzduz.supabase.co">
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&display=block" rel="stylesheet">
  <link rel="stylesheet" href="../assets/70085daa54d49f05a0f0ca04076f60814897b7f6.css">
  <style>
    html, body { margin:0; width:100%; max-width:100%; overflow-x:hidden; background:#000; color:#fff; }
    *, *::before, *::after { box-sizing:border-box; }
    body, p, a, span, button, input, textarea, li { font-family:Pretendard,-apple-system,BlinkMacSystemFont,system-ui,Roboto,"Helvetica Neue","Segoe UI","Apple SD Gothic Neo","Noto Sans KR","Malgun Gothic",sans-serif; }

    .card-overlay { position:absolute; inset:0; background:rgba(0,0,0,0.6); transition:opacity 0.5s ease; pointer-events:none; }
    .group:hover .card-overlay { opacity:0; }
    #mainWorkGrid .card-name,
    #mainWorkGrid .card-type {
      white-space: nowrap !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
      min-width: 0;
    }
    #mainWorkGrid .card-name { flex: 1 1 auto; }
    #mainWorkGrid .card-type { flex: 0 0 auto; }

    .work-reveal { opacity:0; transform:translateY(28px); filter:blur(8px); transition:opacity 0.7s ease, transform 0.7s ease, filter 0.7s ease; transition-delay:var(--work-delay,0s); }
    .work-reveal.work-reveal-in { opacity:1; transform:translateY(0); filter:blur(0); }

    /* Nav */
    .nav-bar { position:fixed; top:0; left:0; right:0; z-index:1000; display:flex; align-items:center; justify-content:space-between; gap:24px; min-height:64px; padding:12px 20px; border-bottom:1px solid rgba(255,255,255,0.08); background:rgba(0,0,0,0.88); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); }
    .nav-bar > a { display:flex; align-items:center; flex:0 0 auto; max-width:160px; }
    .nav-bar > a svg { display:block; height:24px; width:auto; }
    .nav-links { display:flex; align-items:center; gap:12px; margin-left:auto; }
    .nav-links a { display:inline-flex; align-items:center; justify-content:center; min-height:36px; padding:0 14px; border-radius:999px; font-size:13px; font-weight:600; color:#fff; text-decoration:none; transition:background 0.2s ease, color 0.2s ease; }
    .nav-links a:hover { background:#444; }
    .nav-links a.is-active { background:#fff; color:#000; }
    .lang-wrap { position:relative; flex:0 0 auto; }
    .lang-btn { display:inline-flex; align-items:center; gap:6px; min-height:36px; padding:0 14px; border-radius:999px; font-size:13px; font-weight:600; color:#fff; background:none; border:none; cursor:pointer; transition:background 0.2s ease; }
    .lang-btn:hover { background:#444; }
    #langDropdown { display:none; position:absolute; right:0; top:calc(100% + 8px); min-width:132px; background:rgba(0,0,0,0.92); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.15); border-radius:10px; overflow:hidden; z-index:100; }
    #langDropdown a { display:block; padding:10px 16px; color:#fff; font-size:13px; font-weight:500; text-decoration:none; transition:background 0.2s; border-radius:0; }
    #langDropdown a:hover { background:rgba(255,255,255,0.1); }
    .nav-toggle { display:none; align-items:center; justify-content:center; flex-direction:column; width:42px; height:42px; border:1px solid rgba(255,255,255,0.14); border-radius:12px; background:rgba(255,255,255,0.03); cursor:pointer; gap:4px; flex-shrink:0; }
    .nav-toggle span { display:block; width:18px; height:2px; background:#fff; border-radius:999px; transition:transform 0.2s ease, opacity 0.2s ease; transform-origin:center; }

    /* Hero layout */
    .hero-top { display:grid; grid-template-columns:minmax(0,0.8fr) minmax(0,0.2fr); align-items:start; column-gap:72px; row-gap:20px; margin-top:62px; width:100%; }
    .hero-top > * { min-width:0; }
    .hero-logo-wrap { grid-column:1/2; grid-row:1; overflow:hidden; }
    .hero-logo-wrap svg { display:block; width:100%; height:auto; overflow:hidden !important; }
    .hero-logo-copy { margin-top:40px; width:100%; }
    .hero-copy-block { grid-column:2/3; grid-row:1; display:flex; justify-content:flex-start; align-items:flex-start; padding-top:6px; min-width:0; }

    /* Scroll cue */
    .scroll-cue { position:absolute; left:50%; bottom:-132px; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:10px; color:rgba(255,255,255,0.9); pointer-events:none; z-index:20; transition:opacity 0.35s ease, transform 0.35s ease; }
    .scroll-cue.scroll-cue-hidden { opacity:0; transform:translateX(-50%) translateY(14px); }
    .scroll-cue-label { font-size:11px; letter-spacing:0.24em; text-transform:uppercase; opacity:0.72; }
    .scroll-cue-mouse { position:relative; width:28px; height:46px; border:1.5px solid rgba(255,255,255,0.78); border-radius:999px; background:rgba(255,255,255,0.02); animation:scrollCueBob 1.7s cubic-bezier(.34,1.56,.64,1) infinite; }
    .scroll-cue-wheel { position:absolute; top:9px; left:50%; width:4px; height:9px; border-radius:999px; background:rgba(255,255,255,0.92); transform:translateX(-50%); animation:scrollCueWheel 1.7s ease infinite; }
    @keyframes scrollCueBob { 0%,100%{transform:translateY(0) scale(1)} 20%{transform:translateY(2px) scale(0.97,1.03)} 42%{transform:translateY(-8px) scale(1.03,0.98)} 58%{transform:translateY(0) scale(0.985,1.015)} 74%{transform:translateY(-3px) scale(1.01,0.995)} }
    @keyframes scrollCueWheel { 0%{opacity:0;transform:translateX(-50%) translateY(-2px)} 18%{opacity:1;transform:translateX(-50%) translateY(0)} 56%{opacity:1;transform:translateX(-50%) translateY(12px)} 70%,100%{opacity:0;transform:translateX(-50%) translateY(14px)} }

    /* Hero stack */
    .hero-stack { font-family:'Barlow Condensed','Arial Narrow','Helvetica Neue',sans-serif; font-size:4vw; font-weight:300; line-height:1.3; letter-spacing:-0.5px; color:#fff; text-align:left; margin-top:45px; }
    .hero-stack .hero-stack-strong { font:inherit; font-weight:500; }
    .hero-stack em { font-style:normal; color:#fff; }
    .hero-stack .hero-stack-line { display:block; font:inherit; line-height:inherit; letter-spacing:inherit; opacity:0; transform:translateY(18px); will-change:opacity,transform; }
    .hero-stack.hero-stack-animate .hero-stack-line { animation:heroStackReveal 0.55s ease forwards; }
    @keyframes heroStackReveal { 0%{opacity:0;transform:translateY(18px)} 100%{opacity:1;transform:translateY(0)} }

    /* About copy */
    .about-row { position:relative; width:100%; text-align:left; }
    .about-row p { text-align:left !important; font-size:20px !important; line-height:1.55 !important; margin:0 !important; white-space:normal !important; overflow-wrap:anywhere !important; word-break:break-word !important; max-width:100% !important; color:#fff; font-weight:200; }
    .about-row p.typing-effect { opacity:0; transform:translateX(-18px); clip-path:inset(0 100% 0 0); will-change:opacity,transform,clip-path; }
    .about-row p.typing-effect.typing-done { animation:aboutCopyReveal 0.9s ease forwards; }
    @keyframes aboutCopyReveal { 0%{opacity:0;transform:translateX(-18px);clip-path:inset(0 100% 0 0)} 100%{opacity:1;transform:translateX(0);clip-path:inset(0 0 0 0)} }

    /* About blurb */
    .about-blurb { padding:80px 24px; }
    .section-inner { width:100%; max-width:1920px; margin:0 auto; }
    .blurb-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
    .blurb-headline { margin:0 0 20px; font-family:'Barlow Condensed','Arial Narrow','Helvetica Neue',sans-serif; font-size:clamp(36px,4vw,64px); font-weight:500; line-height:1.0; letter-spacing:-0.03em; text-transform:uppercase; }
    .blurb-copy { margin:0 0 32px; font-size:16px; line-height:1.75; color:rgba(255,255,255,0.7); }
    .section-link { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; border:1px solid rgba(255,255,255,0.22); border-radius:999px; font-size:13px; font-weight:600; color:#fff; text-decoration:none; white-space:nowrap; transition:background 0.2s, border-color 0.2s; }
    .section-link:hover { background:rgba(255,255,255,0.08); border-color:rgba(255,255,255,0.4); }
    .pillars { display:grid; gap:16px; }
    .pillar { padding:20px 24px; border:1px solid rgba(255,255,255,0.22); border-radius:16px; background:rgba(255,255,255,0.1); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); }
    .pillar strong { display:block; font-size:15px; font-weight:600; margin-bottom:6px; }
    .pillar span { font-size:14px; color:rgba(255,255,255,0.62); line-height:1.6; }

    /* Footer */
    .footer-addr { display:flex; align-items:center; gap:16px; white-space:nowrap; flex-wrap:wrap; }
    .footer-addr a { color:#ddd; text-decoration:none; display:flex; align-items:center; gap:8px; transition:color 0.2s; }
    .footer-addr a:hover { color:#fff; }
    .footer-copy { color:#ddd; margin-top:8px; display:flex; align-items:center; gap:24px; font-size:14px; flex-wrap:wrap; }
    .footer-copy p { margin:0; }
    .footer-copy a { color:#ddd; text-decoration:none; transition:color 0.2s; }
    .footer-copy a:hover { color:#fff; }

    /* Responsive */
    @media (max-width:900px) {
      .hero-top { grid-template-columns:1fr !important; column-gap:0 !important; row-gap:40px !important; margin-top:32px !important; overflow:hidden !important; }
      .hero-logo-wrap, .hero-copy-block { grid-column:1/-1 !important; grid-row:auto !important; }
      .hero-copy-block { justify-content:flex-start !important; padding-top:0 !important; }
      .hero-stack { font-size:clamp(24px,3.2vw,34px) !important; }
    }
    @media (max-width:768px) {
      .blurb-grid { grid-template-columns:1fr; gap:40px; }
      .nav-bar { padding:12px 16px; }
      .nav-toggle { display:flex; margin-left:auto; }
      .nav-links { display:none !important; position:absolute; top:calc(100% + 8px); left:14px; right:14px; padding:12px; border:1px solid rgba(255,255,255,0.12); border-radius:14px; background:rgba(0,0,0,0.92); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); flex-direction:column; align-items:stretch; gap:8px; z-index:60; box-shadow:0 20px 40px rgba(0,0,0,0.45); }
      .nav-bar.nav-open .nav-links { display:flex !important; }
      .nav-links a, .lang-wrap { width:100%; }
      .nav-links a { justify-content:flex-start; padding:12px 14px; border-radius:12px; }
      .lang-btn { width:100%; justify-content:flex-start; padding:12px 14px; border-radius:12px; }
      #langDropdown { position:static; margin-top:4px; min-width:0; border:none; background:rgba(255,255,255,0.04); backdrop-filter:none; box-shadow:none; }
      .lang-wrap.lang-open #langDropdown { display:block; }
      .nav-bar.nav-open .nav-toggle span:nth-child(1) { transform:translateY(6px) rotate(45deg); }
      .nav-bar.nav-open .nav-toggle span:nth-child(2) { opacity:0; }
      .nav-bar.nav-open .nav-toggle span:nth-child(3) { transform:translateY(-6px) rotate(-45deg); }
      .scroll-cue { display:none !important; }
      #hero-layout { padding-top:36px !important; padding-bottom:20px !important; }
      .hero-top { margin-top:16px !important; row-gap:20px !important; }
      .about-row p { font-size:16px !important; line-height:1.55 !important; }
      .hero-stack { font-size:clamp(60px,19vw,120px) !important; line-height:1.15 !important; letter-spacing:0.01em !important; margin-top:24px !important; font-weight:300 !important; }
      .hero-stack em { color:inherit !important; font-weight:inherit !important; }
      .hero-stack .hero-stack-strong { font-weight:700 !important; }
      .hero-stack .hero-stack-line { display:block !important; margin-right:0 !important; white-space:nowrap !important; }
      .hero-stack em::after { content:"" !important; }
    }
    @media (min-width:769px) { .nav-links { display:flex !important; } .nav-toggle { display:none !important; } }
  
body, p, div, span, h1, h2, h3, h4, h5, h6, a, li, button, td, th {
  word-break: keep-all;
  overflow-wrap: break-word;
}
</style>
