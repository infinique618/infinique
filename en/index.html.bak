                <path class="logo-path letter-q"  d="M968.14,237.44c-48.64,20.19-112.65,6.16-127.22-48.85-4.59-17.36-5-51.1-2.59-69.01,8.78-65.39,93.9-59.66,117.36-7.65l12.45,34.97v-54.39c0-3.69-4.48-12.89-8.08-14.89-6.44-3.57-10.4-.66-16.28.58-.85.18-1.88,1.44-2.62-.67s-.2-2,1.26-2.72c1.64-.8,7.54-2.27,9.48-2.51,19.65-2.4,37.96,3.84,42.92,24.49,5.14,71.52-2.39,145.8,1.25,217.29.91,17.87,3.63,37.45,27.03,26.39l.93,2.51c-16.35,9.04-42.58,5.75-51.3-12.58-1.67-3.51-4.6-8.34-4.6-30.13v-62.84ZM968.01,237.57c-.3-28.48,2.21-56.67-3.33-84.73-5.46-27.62-17.89-60.33-45.83-71.99-28.52-11.9-46.44,2.78-51.36,30.91-4.07,23.24-3.41,69.83,4.24,91.97,14.92,43.13,57.73,47.61,96.28,33.84Z"/>
                <path class="logo-path letter-u"  d="M1244.39,240.56c-.88-.78-14.62,8.16-21.83-1.65-3.15-4.29-4.8-13.46-5.19-18.77-2.72-37.02,3-77.94.07-114.83-2.02-25.42-19.57-35.34-40.62-33.39-1.04.06-2.1.14-3.17.25-1.14.12-4.83.84-7.91,1.79-1.1.3-2.2.61-3.3.96l.1.26,1.27,3.37.12.33c2.69-1.33,5.11-2.19,7.29-2.67,14.13-2.43,16.93,11.14,17.85,26.23,2.51,41.14-4.46,115.52-47.33,135.44-17.52,8.14-39.12,7.4-49.18-11.15-15.89-29.31.1-94.39-7.97-128.76-6.05-25.77-32.63-31.93-54.46-21.45,2.58,4.19,5.42.14,9.56-.41,15.13-2.01,17.62,11.47,18.45,23.32,2.3,33.11-2.92,69.88.09,102.7,3.57,38.97,43.1,52.83,77.05,42.26,23.72-7.39,38.13-28.13,46.51-50.36l7.16-22.91c-.28,10.96-.37,21.84.09,32.5.1,2.19.21,4.37.36,6.54.28,4.21,1.26,10.56,2.34,14.63,6.03,22.85,33.18,27.3,52.68,19.24.21-.05.35-.18.44-.36.48-.89-.34-3.03-.45-3.12Z"/>
                <path class="logo-path letter-e"  d="M1346.74,68.35c24.74-1.72,64.98,4.19,77.04,29.27,10.68,22.2-1.21,31.93-20.18,40.47-11.83,5.33-24.46,9.27-36.34,14.61-18.45,8.3-66.04,31.33-67.88,54.04-.66,8.17,17.66,23.7,24.56,27.49,47.3,25.99,108.56-6.85,129.91-51.97l5.01,2.12c-20.87,44.33-67.82,72.41-117.29,66.18-116.57-14.68-111.59-174.08,5.17-182.2ZM1294.96,197.77c.25-2.72,2.04-5.73,3.58-7.91,11.06-15.68,38.56-30.36,55.73-39.16,10.87-5.57,34.72-13.31,41.09-22.84,5.3-7.93,2.48-24.77-1.61-33.18-11.82-24.31-44.9-24.18-65.7-12.07-34.79,20.25-49.19,76.95-34.55,113.19.39.96.12,2.28,1.48,1.98Z"/>
              </svg>
              <div class="hero-logo-copy">
                <div class="about-row">
                  <p class="typing-effect"><span style="font-weight:600;">PPT EXPERTS, INFINIQUE.</span> From a single idea to a polished final deck — concept, structure, visual finish, and persuasive power that wins.</p>
                </div>
              </div>
            </div>
            <div class="hero-copy-block">
              <div class="hero-stack">ACTIVATE.<br><em>ACCELERATE.</em><br>ACHIEVE.<br><span class="hero-stack-strong">INFINIQUE.</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Work -->
    <section id="work" style="padding:80px 24px;">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2" id="mainWorkGrid"></div>
        <script>
        (function() {
          var EN_LABEL = {'ir':'IR','company-profile':'Company Profile','business-plan':'Business Plan','business-proposal':'Business Proposal','service-intro':'Service Deck','education':'Education'};
          var DEFAULTS = [
            {id:1,name:"Index Robotics",category:"ir",image:"assets/work-01.jpg",showOnMain:true,mainOrder:1,workOrder:1},
            {id:2,name:"Kiuri",category:"company-profile",image:"assets/work-02.jpg",showOnMain:true,mainOrder:2,workOrder:2},
            {id:3,name:"Trimass",category:"ir",image:"assets/work-03.jpg",showOnMain:true,mainOrder:3,workOrder:3},
            {id:4,name:"TVING",category:"service-intro",image:"assets/work-04.jpg",showOnMain:true,mainOrder:4,workOrder:4},
            {id:5,name:"HiKey",category:"business-plan",image:"assets/work-05.jpg",showOnMain:true,mainOrder:5,workOrder:5},
            {id:6,name:"Sweat",category:"ir",image:"assets/work-06.jpg",showOnMain:true,mainOrder:6,workOrder:6},
            {id:7,name:"Mongyu Garden",category:"service-intro",image:"assets/work-07.jpg",showOnMain:true,mainOrder:7,workOrder:7},
            {id:8,name:"ITcon",category:"company-profile",image:"assets/work-08.jpg",showOnMain:true,mainOrder:8,workOrder:8}
          ];
          var grid = document.getElementById('mainWorkGrid');
          if (!grid) return;
          function drawEn(works) {
            var mainWorks = (works || []).slice().filter(function(w){ return w.showOnMain; });
            mainWorks.sort(function(a,b){ return (a.mainOrder||99)-(b.mainOrder||99); });
            var html = '';
            mainWorks.forEach(function(w) {
              var img = w.image||'';
              if (img.indexOf('data:') !== 0 && img.indexOf('http') !== 0) img = img.replace(/^\.\//,'').replace(/^assets\//,'../assets/');
              var label = EN_LABEL[w.category] || w.categoryLabel || w.category;
              var displayName = w.nameEn || w.name;
              html += '<div class="group cursor-pointer"><div class="aspect-square overflow-hidden bg-gray-100 relative rounded-[10px]" style="box-shadow:0 6px 30px rgba(0,0,0,0.7);">'
                + '<img src="'+img+'" alt="'+displayName+'" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105">'
                + '<div class="card-overlay"></div>'
                + '<div class="absolute bottom-3 left-3 right-3 bg-white/40 backdrop-blur-md px-4 py-2.5 rounded-lg flex justify-between items-center gap-2 border border-white/50">'
                + '<span class="card-name text-white text-sm font-medium">'+displayName+'</span><span class="card-type text-white text-sm">'+label+'</span>'
                + '</div></div></div>';
            });
            grid.innerHTML = html;
          }
          function fromSupabaseRow(r) {
            return {
              id: r.id, name: r.name || '', nameEn: r.name_en || '',
              category: r.category || '',
              categoryLabel: r.category_label || '', image: r.image || '',
              showOnMain: !!r.show_on_main, mainOrder: r.main_order || 99, workOrder: r.work_order || 99
            };
          }
          var SB_URL = 'https://umzfjxrrotvwcmurzduz.supabase.co';
          var SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVtemZqeHJyb3R2d2NtdXJ6ZHV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0NTEzMDcsImV4cCI6MjA5MjAyNzMwN30.TR0lKwZeC1_AONrfNgJLYWOykq8u5RBYFGc4q_xpfak';

          var raw = localStorage.getItem('iq_works');
          var cached = null;
          try { cached = raw ? JSON.parse(raw) : null; } catch(e) {}
          drawEn(cached && cached.length ? cached : DEFAULTS);

          fetch(SB_URL + '/rest/v1/works?select=*&order=id', { headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY } })
            .then(function(r){ return r.ok ? r.json() : null; })
            .then(function(data){
              if (data && data.length) {
                var ws = data.map(fromSupabaseRow);
                try { localStorage.setItem('iq_works', JSON.stringify(ws)); } catch(e) {}
                var prev = JSON.stringify(cached || DEFAULTS);
                var next = JSON.stringify(ws);
                if (prev !== next) drawEn(ws);
              }
            })
            .catch(function(){});
        })();
        </script>
      </div>
    </section>

    <!-- About blurb -->
    <section class="about-blurb">
      <div class="section-inner">
        <div class="blurb-grid">
          <div>
            <h2 class="blurb-headline">More than a deck.<br>A whole experience.</h2>
            <p class="blurb-copy">Infinique is a presentation studio that connects strategy and design into one seamless flow. We interpret your brand's context, shape the narrative, and craft every slide to persuade — not just to look good.</p>
            <a href="./contact.html" class="section-link">Contact Us →</a>
          </div>
          <div class="pillars">
            <div class="pillar">
              <strong>Planning & Structure</strong>
              <span>We design information architecture and message hierarchy so every page flows naturally into the next.</span>
            </div>
            <div class="pillar">
              <strong>Brand-Sensitive Design</strong>
              <span>We translate your brand's character into a visual language — consistent, refined, and memorable.</span>
            </div>
            <div class="pillar">
              <strong>Outcome-Oriented Delivery</strong>
              <span>Our goal is work that communicates clearly and persuades effectively in real presentations.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer id="contact" class="bg-black text-white py-20 px-6" style="border-top:1px solid rgba(255,255,255,0.1);">
      <div class="max-w-[1920px] mx-auto">
        <div class="footer-main-row" style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
          <div>
            <span class="footer-addr">
              <span class="text-lg" style="color:#ddd;">Infinique Co., Ltd.</span>
              <span class="text-lg" style="color:#ddd;">|</span>
              <a href="mailto:infinique@infinique.co.kr" class="text-lg hover:text-gray-300 transition-colors" style="color:#ddd;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span>infinique@infinique.co.kr</span>
              </a>
            </span>
            <div class="footer-copy">
              <p>© 2025 Infinique Co., Ltd. All rights reserved.<a href="../admin.html" aria-label="." style="display:inline-block;width:3px;height:3px;background:rgba(255,255,255,0.08);margin-left:6px;vertical-align:middle;border-radius:50%;"></a></p>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:12px;">
            <img src="../assets/infinique_logo.svg" alt="Infinique" style="width:160px;height:auto;">
            <a href="https://infinique.kr" target="_blank" rel="noopener" aria-label="infinique.kr">
              <img src="../assets/dev_logo.svg" alt="Dev logo" style="width:160px;height:auto;">
            </a>
          </div>
        </div>
      </div>
    </footer>

  </div><!-- /z-index wrapper -->

  <!-- Image Modal -->
  <div id="imgModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;cursor:pointer;backdrop-filter:blur(8px);opacity:0;transition:opacity 0.3s ease;">
    <button id="modalClose" style="position:absolute;top:24px;right:24px;background:none;border:none;color:white;font-size:32px;cursor:pointer;z-index:10001;width:48px;height:48px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:background 0.2s;">&times;</button>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%;padding:40px;">
      <img id="modalImg" src="" alt="" style="max-width:90vw;max-height:80vh;object-fit:contain;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,0.5);transform:scale(0.9);transition:transform 0.3s ease;">
      <div id="modalInfo" style="margin-top:16px;text-align:center;opacity:0;transition:opacity 0.3s ease 0.1s;">
        <span id="modalName" style="color:white;font-size:18px;font-weight:600;"></span>
        <span style="color:rgba(255,255,255,0.4);margin:0 12px;">|</span>
        <span id="modalType" style="color:rgba(255,255,255,0.6);font-size:16px;"></span>
      </div>
    </div>
  </div>

  <script>
  (function(){
    var modal=document.getElementById('imgModal'),modalImg=document.getElementById('modalImg'),modalName=document.getElementById('modalName'),modalType=document.getElementById('modalType'),modalInfo=document.getElementById('modalInfo'),modalClose=document.getElementById('modalClose');
    function openModal(src,name,type){modalImg.src=src;modalName.textContent=name;modalType.textContent=type;modal.style.display='block';requestAnimationFrame(function(){modal.style.opacity='1';modalImg.style.transform='scale(1)';modalInfo.style.opacity='1';});var sw=window.innerWidth-document.documentElement.clientWidth;document.body.style.overflow='hidden';document.body.style.paddingRight=sw+'px';}
    function closeModal(){modal.style.opacity='0';modalImg.style.transform='scale(0.9)';modalInfo.style.opacity='0';setTimeout(function(){modal.style.display='none';document.body.style.overflow='';document.body.style.paddingRight='';},300);}
    document.querySelectorAll('#work .group.cursor-pointer').forEach(function(card){card.addEventListener('click',function(){var img=card.querySelector('img');var labels=card.querySelectorAll('.absolute span');openModal(img.src,labels[0]?labels[0].textContent:'',labels[1]?labels[1].textContent:'');});});
    modal.addEventListener('click',function(e){if(e.target===modal||e.target===modal.querySelector('div'))closeModal();});
    modalClose.addEventListener('click',closeModal);
    modalClose.addEventListener('mouseenter',function(){this.style.background='rgba(255,255,255,0.1)';});
    modalClose.addEventListener('mouseleave',function(){this.style.background='none';});
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal();});
  })();
  </script>

  <script>
  (function(){
    var heroLayout=document.getElementById('hero-layout');
    if(!heroLayout)return;
    heroLayout.style.position='relative';
    var scrollCue=document.createElement('div');
    scrollCue.className='scroll-cue';
    scrollCue.setAttribute('aria-hidden','true');
    scrollCue.innerHTML='<div class="scroll-cue-mouse"><span class="scroll-cue-wheel"></span></div><div class="scroll-cue-label">Scroll</div>';
    heroLayout.appendChild(scrollCue);
    function hide(){scrollCue.classList.add('scroll-cue-hidden');window.removeEventListener('scroll',hide);window.removeEventListener('wheel',hide);window.removeEventListener('touchstart',hide);}
    if(window.scrollY>8){hide();return;}
    window.addEventListener('scroll',hide,{passive:true});
    window.addEventListener('wheel',hide,{passive:true});
    window.addEventListener('touchstart',hide,{passive:true});
  })();
  </script>

  <script>
  (function(){
    var heroStack=document.querySelector('.hero-stack');
    if(!heroStack||heroStack.querySelector('.hero-stack-line'))return;
    var lines=heroStack.innerHTML.split('<br>');
    heroStack.innerHTML=lines.map(function(l){return'<span class="hero-stack-line">'+l+'</span>';}).join('');
    window.setTimeout(function(){
      heroStack.classList.add('hero-stack-animate');
      heroStack.querySelectorAll('.hero-stack-line').forEach(function(line,i){line.style.animationDelay=(i*0.18)+'s';});
    },1650);
  })();
  </script>

  <script>
  (function(){
    var p=document.querySelector('.about-row p');
    if(!p||p.dataset.typingReady==='true')return;
    p.dataset.typingReady='true';
    p.classList.add('typing-effect');
    window.setTimeout(function(){p.classList.add('typing-done');},0);
  })();
  </script>

  <script>
  (function(){
    var navBar=document.querySelector('.nav-bar');
    var nav=navBar?navBar.querySelector('nav'):null;
    var btn=document.getElementById('langToggle');
    var dd=document.getElementById('langDropdown');
    var langWrap=btn?btn.parentElement:null;
    var navToggle;
    var mq=window.matchMedia('(max-width:768px)');
    function closeMenu(){if(!navBar||!navToggle)return;navBar.classList.remove('nav-open');navToggle.setAttribute('aria-expanded','false');}
    function closeLang(){if(!dd)return;dd.style.display='none';if(langWrap)langWrap.classList.remove('lang-open');}
    function sync(){if(!mq.matches){closeMenu();closeLang();}}
    if(navBar&&nav){
      navToggle=document.createElement('button');
      navToggle.type='button';navToggle.className='nav-toggle';
      navToggle.setAttribute('aria-label','Toggle menu');navToggle.setAttribute('aria-expanded','false');navToggle.setAttribute('aria-controls','siteNav');
      navToggle.innerHTML='<span></span><span></span><span></span>';
      navBar.appendChild(navToggle);
      navToggle.addEventListener('click',function(e){e.stopPropagation();var open=navBar.classList.toggle('nav-open');navToggle.setAttribute('aria-expanded',open?'true':'false');if(!open)closeLang();});
    }
    if(btn&&dd){btn.addEventListener('click',function(e){e.stopPropagation();if(mq.matches&&langWrap){var isOpen=langWrap.classList.toggle('lang-open');dd.style.display=isOpen?'block':'none';return;}dd.style.display=dd.style.display==='block'?'none':'block';});}
    document.addEventListener('click',function(e){closeLang();if(navBar&&navBar.classList.contains('nav-open')&&navToggle&&!navBar.contains(e.target))closeMenu();});
    if(mq.addEventListener){mq.addEventListener('change',sync);}else if(mq.addListener){mq.addListener(sync);}
    window.addEventListener('resize',sync);sync();
  })();
  function setLang(lang){
    if(lang==='ko'){window.location.href='../index.html';return;}
    var dd=document.getElementById('langDropdown');var lb=document.getElementById('langLabel');
    if(dd){dd.style.display='none';if(dd.parentElement)dd.parentElement.classList.remove('lang-open');}
    if(lb)lb.textContent=lang.toUpperCase();
  }
  </script>

  <script>
  (function(){
    var cards=Array.prototype.slice.call(document.querySelectorAll('#work .group.cursor-pointer'));
    if(!cards.length)return;
    cards.forEach(function(c){c.classList.add('work-reveal');c.style.setProperty('--work-delay','0s');});
    if(!('IntersectionObserver'in window)){cards.forEach(function(c){c.classList.add('work-reveal-in');});return;}
    var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(!e.isIntersecting)return;e.target.classList.add('work-reveal-in');obs.unobserve(e.target);});},{threshold:0.18,rootMargin:'0px 0px -8% 0px'});
    cards.forEach(function(c){obs.observe(c);});
  })();
  </script>

</body>
</html>
