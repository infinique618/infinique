<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Infinique — Presentation Design Studio | Strategy, Structure, Design</title>
  <link rel="icon" type="image/x-icon" href="../assets/favicon.ico">
  <meta name="description" content="Infinique is a presentation design studio connecting strategy, structure, and visual design into one seamless flow. IR decks, company profiles, business plans, proposals, and service decks — crafted for clarity and persuasion.">
  <meta name="keywords" content="presentation design, PPT design studio, investor deck design, pitch deck, company profile design, business plan design, Infinique">
  <meta name="author" content="Infinique">
  <link rel="canonical" href="https://infinique.kr/en/">
  <link rel="alternate" hreflang="ko" href="https://infinique.kr/">
  <link rel="alternate" hreflang="en" href="https://infinique.kr/en/">
  <link rel="alternate" hreflang="x-default" href="https://infinique.kr/">
  <meta property="og:title" content="Infinique — Presentation Design Studio">
  <meta property="og:description" content="Presentation design studio connecting strategy, structure, and visual design into one seamless flow.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://infinique.kr/en/">
  <meta property="og:site_name" content="Infinique">
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="ko_KR">
